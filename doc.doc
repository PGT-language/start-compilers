package // названия пакета к примеру main как в >Go {реализовано}

package main // только главный входной файл {реализовано}

package cli // библиотечный пакет, лучше держать в отдельной директории {реализовано}

// как в Go: одна директория = один пакет
// если в той же директории, где package main, создать package cli и импортировать его,
// это будет ошибкой импорта

// правильно:
// test-cli.pgt -> package main
// cli/create-file.pgt -> package cli

from // путь к файлу import // импортируем что то из файла {реализовано}

function(что то) // как в go {реализовано}

function(main) // вход в програму {реализовано}

if // {реализовано}

else // {реализовано}

while // цикл {реализовано}

true // логическая истина {реализовано}

false // логическая ложь {реализовано}

int // {реализовано}

float // {реализовано}

string // {реализовано}

print // {реализовано}

println // {реализовано}

create::file("c") // создания файла {реализовано}

write::file("w") // запись файла {реализовано}

read::file("r") // чтение файла {реализовано}

close::file("h") // закрытие файла {реализовано}

delete::file("d") // удаление файла {реализовано}

call(test) // название точки вызова вот так call(имя функции) {реализовано}

print(arg, "{int}") // посли вызова функции мы печатаем что находыться в function  {arg} и указываем тип данных {int} {реализовано}

cout(input, "{int}") // для работы с пользовательским вводом {реализовано}

while true { {реализовано}
    print("loop") {реализовано}
} // бесконечный цикл, пока без break {реализовано}

printg(" {реализовано}
    какой то много строчный тест
    Test,
    Test,
    Test,
    Test,
    Test,
    Test,
    Test,
")

return 1 // окончание function {реализовано}

return 0 // окончание программы {реализовано}

net::get("https://example.com") // transport выбирается автоматически из URL {реализовано}

net::post("https://example.com", "{data}") // transport выбирается автоматически из URL {реализовано}

net::http::get("http://example.com") // получение данных по url, Linux-only через libcurl {реализовано}

net::http::post("http://example.com", "{data}") // отправка данных по url, Linux-only через libcurl {реализовано}

net::https::get("https://example.com") // получение данных по https, Linux-only через OpenSSL {реализовано}

net::https::post("https://example.com", "{data}") // отправка данных по https, Linux-only через OpenSSL {реализовано}

net::serve("127.0.0.1", 8083, body) // запуск HTTP сервера на указанном адресе и порту {реализовано}
// Если body начинается с "file:", сервер читает файл и возвращает его содержимое
// Для GET / возвращает файл или body
// Для GET /api возвращает JSON {"message": "Hello from API"}
// Для POST /api парсит JSON из тела запроса и возвращает его обратно
// Поддерживает HTML файлы с правильным Content-Type

json_parse(json_string) // парсит JSON строку в объект или массив {реализовано}

json_stringify(value) // сериализует объект или массив в JSON строку {реализовано}

read_file("path/to/file") // читает файл и возвращает его содержимое как строку {реализовано}

read::file("path/to/file") // новый namespace-синтаксис для чтения файла как выражения {реализовано}

request_method() // возвращает HTTP метод текущего запроса внутри handler-функции {реализовано}

request_path() // возвращает путь текущего запроса внутри handler-функции {реализовано}

request_body() // возвращает тело текущего HTTP запроса внутри handler-функции {реализовано}

request_json() // парсит тело текущего HTTP запроса как JSON {реализовано}

request::method() // новый namespace-синтаксис для метода HTTP запроса {реализовано}

request::path() // новый namespace-синтаксис для пути HTTP запроса {реализовано}

request::body() // новый namespace-синтаксис для тела HTTP запроса {реализовано}

request::json() // новый namespace-синтаксис для JSON тела HTTP запроса {реализовано}

open_log("path/to/logfile.log") // открывает файл для логирования и переключает вывод логов в файл {реализовано}

log("message") // логирует сообщение с уровнем INFO {реализовано}

log("debug", "message") // логирует сообщение с выбранным уровнем {реализовано}

log("message", "debug") // альтернативный порядок: сообщение, потом уровень {реализовано}

log_trace("message") // уровень TRACE {реализовано}

log_debug("message") // уровень DEBUG {реализовано}

log_info("message") // уровень INFO {реализовано}

log_notice("message") // уровень NOTICE {реализовано}

log_warn("message") // уровень WARN {реализовано}

log_warning("message") // alias для WARN {реализовано}

log_error("message") // уровень ERROR {реализовано}

log_critical("message") // уровень CRITICAL {реализовано}

log_fatal("message") // alias для CRITICAL {реализовано}

log_critecal("message") // alias для CRITICAL, чтобы не ломаться от опечатки {реализовано}

log_console() // переключает логи только в консоль {реализовано}

log_file("path/to/logfile.log") // открывает файл и переключает логи только в файл {реализовано}

log_output("console") // выбирает вывод логов в консоль {реализовано}

log_output("file") // выбирает вывод логов в уже открытый файл {реализовано}

set_log_output("console") // alias для log_output {реализовано}

log::debug("message") // новый namespace-синтаксис логирования DEBUG {реализовано}

log::info("message") // новый namespace-синтаксис логирования INFO {реализовано}

log::warn("message") // новый namespace-синтаксис логирования WARN {реализовано}

log::error("message") // новый namespace-синтаксис логирования ERROR {реализовано}

log::critical("message") // новый namespace-синтаксис логирования CRITICAL {реализовано}

log::file("path/to/logfile.log") // открыть файл и логировать только туда {реализовано}

log::console() // переключить логи только в консоль {реализовано}

log::output("file") // выбрать уже открытый файл как вывод логов {реализовано}

Логирование: сервер автоматически логирует старт, маршруты, запросы, ответы и ошибки. Вывод всегда один: либо консоль, либо файл. По умолчанию консоль; open_log/log_file/log::file переключают в файл. {реализовано}

json::parse(json_string) // namespace-синтаксис JSON decode/unmarshal {реализовано}

json::stringify(value) // namespace-синтаксис JSON encode/marshal {реализовано}

json::decode(json_string) // alias для json::parse, ближе к Go naming {реализовано}

json::unmarshal(json_string) // alias для json::parse, как json.Unmarshal в Go {реализовано}

json::encode(value) // alias для json::stringify {реализовано}

json::marshal(value) // alias для json::stringify, как json.Marshal в Go {реализовано}

json::object("key", value, "next", value) // создание JSON object без ручной строки {реализовано}

json::write("path.json", value) // запись объекта/массива/значения в JSON-файл {реализовано}

json::read("path.json") // чтение JSON-файла и парсинг в object/array {реализовано}

sql::open("app.sql") // открыть SQL script backend без внешних зависимостей {реализовано}

sql::exec("CREATE TABLE users (id INTEGER)") // записать SQL запрос в backend {реализовано}

sql::table("users", "id INTEGER PRIMARY KEY, name TEXT") // создать CREATE TABLE IF NOT EXISTS {реализовано}

sql::insert("users", json::object("name", "Pabla")) // создать INSERT из JSON object {реализовано}

orm::table("users", "id INTEGER PRIMARY KEY, name TEXT") // ORM alias для table {реализовано}

orm::save("users", json::object("name", "Pabla")) // ORM alias для insert/save {реализовано}

pgt generate component logging // генератор компонента logging {реализовано}

pgt g component logging // короткая форма генератора {реализовано}

pgt generate file src/new_file main // генератор нового .pgt файла {реализовано}

pgt generate model user name:string email:string // генератор ORM модели {реализовано}

pgt generate class user name:string email:string // alias для генератора ORM модели {реализовано}

from "components/logging" import to_file, to_console, debug, info, warn, error, critical // подключение logging-компонента {реализовано}

Пример записи формы в JSON-файл:
function(api) { {реализовано}
    if (request::method() == "POST") {
        json::write("messages.json", request::json())
        return json::object("status", "saved")
    }
    return 1
}

Маршруты сервера:
- GET / : возвращает HTML файл или тело
- GET /api : возвращает {"message": "Hello from API"}
- GET /data : возвращает {"data": [1, 2, 3, 4, 5]}
- GET /status : возвращает {"status": "running", "uptime": "unknown"}
- POST /api : принимает JSON, возвращает его обратно
- POST /data : принимает данные, возвращает подтверждение
