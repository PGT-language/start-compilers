PGT language notes

Пакеты

package main
// главный входной пакет программы. Файл, который запускается через pgt run,
// обязан начинаться с package main.

package cli
// обычный библиотечный пакет.

Правило как в Go:
одна директория = один пакет.

Если файл package main лежит в директории test_code, то все .pgt файлы прямо в test_code
тоже должны быть package main. Если рядом лежит файл package test, компилятор откажется
запускать программу. Такой пакет нужно вынести в свою папку:

правильно:
test_code/test-cli.pgt       -> package main
test_code/cli/create-file.pgt -> package cli
test_code/cli/delete-file.pgt -> package cli

неправильно:
test_code/test-cli.pgt  -> package main
test_code/test-test.pgt -> package test

Импорты

from "cli" import create_file, delete_file
// импорт пакета-папки. Компилятор загрузит .pgt файлы из директории cli
// и найдёт функции create_file, delete_file внутри package cli.

from "cli/create-file" import create_file
// старый файловый импорт тоже работает.

from "std/io" import std_note
from "std/math" import std_print_sum
from "std/text" import std_yes_no
from "std/net" import std_http_get, std_http_post_text, std_http_post_bytes
// стандартная библиотека.

Функции

function(main) {
    return 1
}

function(print_name, name + string) {
    println(name, "{string}")
    return 1
}

call(print_name, "Pabla")

Типы

int
float
string
bool
bytes

Примеры:

count + int = 10
price + float = 2.5
name + string = "PGT"
running + bool = true
body + bytes = "hello"

cout(input, "{int}")
cout(answer, "{bool}")
cout(raw, "{bytes}")

Печать

print("text")
println("text")
printg("without newline")

println(count, "{int}")
println(price, "{float}")
println(name, "{string}")
println(running, "{bool}")
println(body, "{bytes}")

Условия и циклы

if (running == true) {
    println("server is running")
} else {
    println("server is stopped")
}

while running {
    println("loop")
}

Файлы

create::file("test.txt")
write::file("test.txt", "content")
read::file("test.txt")
close::file("test.txt")
delete::file("test.txt")

Сеть

net::get("https://example.com")
net::post("https://example.com", "data")

net::http::get("http://example.com")
net::http::post("http://example.com", "data")

net::https::get("https://example.com")
net::https::post("https://example.com", "data")

Через stdlib:

from "std/net" import std_http_get, std_http_post_bytes

function(main) {
    payload + bytes = "hello"
    call(std_http_get, "https://example.com")
    call(std_http_post_bytes, "https://example.com", payload)
    return 1
}
return 0

Завершение

return 1
// окончание function

return 0
// окончание программы
