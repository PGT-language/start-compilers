package // названия пакета к примеру main как в >Go

from // путь к файлу import // импортируем что то из файла

function(что то) // как в go 

function(main) // вход в програму

if // 

else // 

while // цикл

true // логическая истина

false // логическая ложь

int //

float //

string //

print // 

println //

create::file("c") // создания файла

write::file("w") // запись файла

read::file("r") // чтение файла

close::file("h") // закрытие файла

delete::file("d") // удаление файла

call(test) // название точки вызова вот так

print(arg, "{int}") // посли вызова функции мы печатаем что находыться в function 

cout(input, "{int}") // для работы с пользовательским вводом

while true {
    print("loop")
} // бесконечный цикл, пока без break

printg("
    какой то много строчный тест
    Test,
    Test,
    Test,
    Test,
    Test,
    Test,
    Test,
")

return 1 // окончание function

return 0 // окончание программы

net::http::get("http://example.com") // получение данных по url, Linux-only

net::http::post("http://example.com", "{data}") // отправка данных по url, Linux-only

net::https::get("https://example.com") // получение данных по https, Linux-only через OpenSSL

net::https::post("https://example.com", "{data}") // отправка данных по https, Linux-only через OpenSSL